<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Theme.MasterDriving" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_gold</item>
        <item name="colorOnSecondary">@color/brand_blue</item>
        <item name="colorSurface">@color/surface_white</item>
        <item name="colorOnSurface">@color/gray_900</item>
        <!-- For Material3 -->
        <item name="colorPrimaryContainer">@color/brand_blue_medium</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondaryContainer">@color/brand_gold</item>
        <item name="colorOnSecondaryContainer">@color/brand_blue_darker</item>
        <item name="android:statusBarColor">@color/brand_blue</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.MasterDriving.Splash" parent="Theme.MasterDriving">
        <item name="android:statusBarColor">@color/brand_blue</item>
        <item name="android:navigationBarColor">@color/brand_blue</item>
        <item name="android:windowBackground">@color/brand_blue</item>
    </style>

    <!-- Auth Theme -->
    <style name="Theme.MasterDriving.Auth" parent="Theme.MasterDriving">
        <item name="android:statusBarColor">@color/brand_blue</item>
        <item name="android:windowBackground">@color/brand_blue</item>
    </style>

    <!-- TextInput Styles -->
    <style name="MasterDriving.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/brand_blue</item>
        <item name="hintTextColor">@color/brand_blue</item>
    </style>

    <!-- Button Styles -->
    <style name="MasterDriving.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="MasterDriving.Button.Gold" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_gold</item>
        <item name="android:textColor">@color/brand_blue</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="MasterDriving.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Card Style -->
    <style name="MasterDriving.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="MasterDriving.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/white</item>
        <item name="itemIconTint">@drawable/bottom_nav_selector</item>
        <item name="itemTextColor">@drawable/bottom_nav_selector</item>
    </style>

    <!-- Tab Layout -->
    <style name="MasterDriving.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabIndicatorColor">@color/brand_gold</item>
        <item name="tabSelectedTextColor">@color/white</item>
        <item name="tabTextColor">@color/white</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabGravity">fill</item>
        <item name="tabMode">fixed</item>
    </style>

    <!-- Toolbar -->
    <style name="MasterDriving.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/brand_blue</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/white</item>
    </style>

    <!-- Typography -->
    <style name="MasterDriving.Text.Headline" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/brand_blue</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MasterDriving.Text.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/gray_900</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MasterDriving.Text.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/gray_600</item>
    </style>

    <style name="MasterDriving.Text.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/gray_500</item>
    </style>

    <!-- Bottom Navigation Tab Label Styles -->
    <style name="BottomNavTextActive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_blue</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/gray_400</item>
    </style>

</resources>
