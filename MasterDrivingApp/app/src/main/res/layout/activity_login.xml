<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_blue_gradient">

    <!-- ════════════════════════════════ -->
    <!-- TOP BRANDING PANEL — Responsive -->
    <!-- ════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.32"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- Logo circle -->
        <FrameLayout
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:background="@drawable/bg_icon_circle_white"
            android:layout_marginBottom="14dp"
            android:elevation="8dp">
            <ImageView
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:src="@drawable/master_logo"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Master Driving School"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Metro Manila's #1 Choice"
            android:textColor="#BBDDFF"
            android:textSize="13sp"
            android:textStyle="normal"
            android:alpha="0.9" />
    </LinearLayout>

    <!-- ════════════════════════════════════ -->
    <!-- WHITE FORM CARD (Floating Effect)   -->
    <!-- ════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.68"
        app:cardCornerRadius="32dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="-32dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="36dp"
                android:paddingBottom="64dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textColor="@color/brand_blue_dark"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Please sign in to continue"
                    android:textColor="@color/gray_500"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="28dp" />

                <!-- Error banner -->
                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="#FFF5F5"
                    android:padding="12dp"
                    android:textColor="#DC2626"
                    android:textSize="13sp"
                    android:drawableStart="@android:drawable/stat_notify_error"
                    android:drawablePadding="8dp"
                    android:visibility="gone" />

                <!-- Email label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="@color/gray_700"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <!-- Email field -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:boxStrokeColor="@color/brand_blue"
                    app:hintEnabled="false"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidthFocused="2dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="name@example.com"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/gray_900"
                        android:textColorHint="@color/gray_400"
                        android:textSize="15sp"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="@color/gray_700"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <!-- Password field -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:id="@+id/til_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:boxStrokeColor="@color/brand_blue"
                    app:hintEnabled="false"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/gray_400"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidthFocused="2dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:textColor="@color/gray_900"
                        android:textColorHint="@color/gray_400"
                        android:textSize="15sp"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Forgot Password -->
                <TextView
                    android:id="@+id/tv_forgot_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot Password?"
                    android:textColor="@color/brand_blue"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_gravity="end"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Terms checkbox -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="28dp">
                    <CheckBox
                        android:id="@+id/cb_terms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/brand_blue" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I agree to the "
                        android:textColor="@color/gray_600"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tv_terms_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Terms &amp; Conditions"
                        android:textColor="@color/brand_blue"
                        android:textStyle="bold"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_terms_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please accept terms to continue"
                    android:textColor="@color/error"
                    android:textSize="12sp"
                    android:layout_marginTop="-24dp"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:visibility="gone"
                    android:indeterminateTint="@color/brand_blue"
                    android:layout_marginBottom="16dp" />

                <!-- LOGIN Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sign_in"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="SIGN IN"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:letterSpacing="0.1"
                    app:backgroundTint="#1E3A8A"
                    app:cornerRadius="16dp"
                    app:elevation="8dp"
                    android:layout_marginBottom="24dp" />

                <!-- Register Link -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New student? "
                        android:textColor="@color/gray_600"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tv_sign_up"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enroll Now"
                        android:textColor="@color/brand_blue"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</LinearLayout>
