<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top">

            <!-- Course Icon Box -->
            <androidx.cardview.widget.CardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F3F4F6">
                <TextView
                    android:id="@+id/tv_course_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🚗"
                    android:textSize="26sp" />
            </androidx.cardview.widget.CardView>

            <!-- Course Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tv_course_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Theoretical Driving Course"
                    android:textColor="@color/gray_900"
                    android:textSize="17sp"
                    android:lineSpacingExtra="2sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_course_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PDC · V1-Tricycle"
                    android:textColor="@color/brand_blue"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LTO Accredited"
                    android:textColor="@color/gray_500"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Price -->
            <TextView
                android:id="@+id/tv_course_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱2,500"
                android:textColor="@color/brand_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/tv_course_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Short description of the course content."
            android:textColor="@color/gray_600"
            android:textSize="13.5sp"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="3sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Bottom Action Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chip_blue"
                android:backgroundTint="#F0F5FF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/tv_course_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ 15 Hours"
                    android:textColor="@color/brand_blue"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_enroll"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="ENROLL"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="13sp"
                android:letterSpacing="0.06"
                app:backgroundTint="@color/brand_blue"
                app:cornerRadius="12dp"
                app:elevation="0dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
