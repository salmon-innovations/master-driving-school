<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Main Branch Badge (controlled by visibility) -->
        <TextView
            android:id="@+id/tv_main_branch_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Main Branch"
            android:textColor="@color/brand_blue"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_gold_badge"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <!-- Branch Name -->
        <TextView
            android:id="@+id/tv_branch_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="V-luna Main Branch"
            android:textColor="@color/brand_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Address Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_branches"
                app:tint="@color/brand_blue"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Address"
                    android:textColor="@color/gray_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_branch_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="123 Example Street, Quezon City"
                    android:textColor="@color/gray_500"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Phone Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/stat_sys_phone_call"
                app:tint="@color/brand_blue"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone"
                    android:textColor="@color/gray_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_branch_contact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0915 644 9441"
                    android:textColor="@color/gray_500"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hours Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/brand_blue"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hours"
                    android:textColor="@color/gray_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8:00 AM - 5:00 PM"
                    android:textColor="@color/gray_500"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons (matching web design) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Get Directions Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_get_directions"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Get Directions"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/brand_blue"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/brand_blue"
                app:strokeWidth="2dp"
                app:cornerRadius="22dp" />

            <!-- Enroll Now Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_enroll_now"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Enroll Now"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/brand_blue"
                app:cornerRadius="22dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
