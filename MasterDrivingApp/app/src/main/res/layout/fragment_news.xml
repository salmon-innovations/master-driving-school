<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_50">

    <!-- Hero Header — matches web "NEWS & UPDATES" banner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_blue"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="28dp"
        android:paddingBottom="28dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEWS &amp; UPDATES"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Stay informed with the latest announcements,\nroad safety tips, and school events."
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Coming Soon Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/news_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp">

                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_news"
                        app:tint="@color/gray_200"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stay Tuned!"
                        android:textColor="@color/brand_blue"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Latest news and school announcements\nwill appear here."
                        android:textColor="@color/gray_500"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="24dp" />

                    <!-- Visit Website Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_visit_website"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Visit masterdriving.ph"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/brand_blue"
                        app:cornerRadius="24dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tip Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/brand_gold">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 Road Safety Tip"
                        android:textColor="@color/brand_blue_darker"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Always wear your seatbelt and follow traffic rules. Safe driving starts with you!"
                        android:textColor="@color/brand_blue_dark"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
