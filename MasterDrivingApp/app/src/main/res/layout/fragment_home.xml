<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ════════════════════════════════════════ -->
            <!-- TOP APP BAR with Logo                   -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/brand_blue"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/master_logo"
                    android:scaleType="fitCenter" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MASTER DRIVING SCHOOL"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Metro Manila's #1 Driving School"
                        android:textColor="#CCffffff"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Enroll Now small button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_topbar_enroll"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Enroll Now"
                    android:textColor="@color/brand_blue"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/brand_gold"
                    app:cornerRadius="16dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <!-- ════════════════════════════════════════ -->
            <!-- IMAGE SLIDER (ViewPager2)                -->
            <!-- ════════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/slider_viewpager"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Dot Indicators -->
                <LinearLayout
                    android:id="@+id/slider_dots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:orientation="horizontal"
                    android:paddingBottom="10dp" />
            </FrameLayout>

            <!-- ════════════════════════════════════════ -->
            <!-- STATS BANNER                            -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_blue"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5+" android:textColor="@color/brand_gold" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Years" android:textColor="#CCffffff" android:textSize="10sp" android:gravity="center" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp" android:background="#44ffffff" android:layout_gravity="center_vertical" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15" android:textColor="@color/brand_gold" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Branches" android:textColor="#CCffffff" android:textSize="10sp" android:gravity="center" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp" android:background="#44ffffff" android:layout_gravity="center_vertical" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="40K+" android:textColor="@color/brand_gold" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Students" android:textColor="#CCffffff" android:textSize="10sp" android:gravity="center" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp" android:background="#44ffffff" android:layout_gravity="center_vertical" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="98%" android:textColor="@color/brand_gold" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pass Rate" android:textColor="#CCffffff" android:textSize="10sp" android:gravity="center" />
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════════════ -->
            <!-- QUICK ACTION CARDS                      -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/white"
                android:padding="12dp">

                <!-- Book Schedule -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_book"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/brand_blue">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingTop="18dp" android:paddingBottom="18dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_schedule" app:tint="@color/white" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Book" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Schedule" android:textColor="#E0FFFFFF" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Our Courses -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_courses"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/brand_gold">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingTop="18dp" android:paddingBottom="18dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_courses" app:tint="@color/brand_blue_darker" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Our" android:textColor="@color/brand_blue_darker" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Courses" android:textColor="@color/brand_blue_medium" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Find Branch -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_branches"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/brand_blue">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingTop="18dp" android:paddingBottom="18dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_branches" app:tint="@color/white" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Branch" android:textColor="#E0FFFFFF" android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ════════════════════════════════════════ -->
            <!-- WHY CHOOSE US                           -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8F9FC"
                android:padding="16dp">

                <!-- Section Header -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <View android:layout_width="4dp" android:layout_height="22dp" android:background="@color/brand_gold" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Why Choose Us?" android:textColor="@color/brand_blue" android:textSize="17sp" android:textStyle="bold" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Metro Manila's most trusted driving school" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginBottom="14dp" android:layout_marginStart="14dp" />

                <!-- Feature Row 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">

                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="28sp" android:gravity="center" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LTO Accredited" android:textColor="@color/brand_blue" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="6dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Official LTO-approved driving school" android:textColor="#6B7280" android:textSize="10sp" android:gravity="center" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❄️" android:textSize="28sp" android:gravity="center" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AC Vehicles" android:textColor="@color/brand_blue" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="6dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Air-conditioned training cars" android:textColor="#6B7280" android:textSize="10sp" android:gravity="center" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Feature Row 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👨‍🏫" android:textSize="28sp" android:gravity="center" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Expert Instructors" android:textColor="@color/brand_blue" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="6dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Certified professional trainers" android:textColor="#6B7280" android:textSize="10sp" android:gravity="center" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰" android:textSize="28sp" android:gravity="center" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Affordable" android:textColor="@color/brand_blue" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="6dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Budget-friendly packages" android:textColor="#6B7280" android:textSize="10sp" android:gravity="center" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════════════ -->
            <!-- HOW IT WORKS                            -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">

                <!-- Section Header -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                    <View android:layout_width="4dp" android:layout_height="22dp" android:background="@color/brand_gold" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Get Started in 3 Steps" android:textColor="@color/brand_blue" android:textSize="17sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Step 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp" android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="1" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_step_circle_blue" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Choose Your Course" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TDC, PDC, or Bundle packages" android:textColor="#6B7280" android:textSize="12sp" />
                    </LinearLayout>
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_courses" android:alpha="0.15" android:padding="6dp"/>
                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp" android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="2" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_step_circle_gold" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pick a Schedule" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Choose date, time &amp; branch" android:textColor="#6B7280" android:textSize="12sp" />
                    </LinearLayout>
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_schedule" android:alpha="0.15" android:padding="6dp"/>
                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="3" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_step_circle_blue" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Start Learning!" android:textColor="#111827" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Begin your journey to safe driving" android:textColor="#6B7280" android:textSize="12sp" />
                    </LinearLayout>
                    <TextView android:layout_width="48dp" android:layout_height="48dp" android:text="🚗" android:textSize="28sp" android:gravity="center" android:alpha="0.3" />
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════════════ -->
            <!-- TRUST BADGES                            -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_blue"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <View android:layout_width="4dp" android:layout_height="18dp" android:background="@color/brand_gold" android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trusted &amp; Accredited By" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="24sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LTO" android:textColor="@color/brand_gold" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Accredited" android:textColor="#CCffffff" android:textSize="9sp" android:gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✅" android:textSize="24sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DOTr" android:textColor="@color/brand_gold" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Certified" android:textColor="#CCffffff" android:textSize="9sp" android:gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛡️" android:textSize="24sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Insured" android:textColor="@color/brand_gold" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fully Covered" android:textColor="#CCffffff" android:textSize="9sp" android:gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="24sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5-Star" android:textColor="@color/brand_gold" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rating" android:textColor="#CCffffff" android:textSize="9sp" android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════════════ -->
            <!-- CTA SECTION                             -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/brand_gold"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to Start Your Driving Journey?"
                    android:textColor="@color/brand_blue"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join 40,000+ satisfied students across Metro Manila"
                    android:textColor="@color/brand_blue_dark"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_book_lesson"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="📅  Book Your First Lesson"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/brand_blue"
                    app:cornerRadius="25dp"
                    android:layout_marginBottom="10dp" />

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📞" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0915 644 9441" android:textColor="@color/brand_blue" android:textSize="13sp" android:textStyle="bold" />
