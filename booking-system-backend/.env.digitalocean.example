# DigitalOcean App Platform + Managed PostgreSQL example

# App
NODE_ENV=production
PORT=8080

# Frontend domain(s) allowed by CORS (comma-separated)
FRONTEND_URL=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Public backend URL (used by callbacks/webhooks)
BACKEND_URL=https://your-backend-domain.com

# PostgreSQL (Managed DB)
# Use one connection string from DigitalOcean database connection details
DATABASE_URL=postgresql://doadmin:YOUR_PASSWORD@db-postgresql-xxx.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# SSL behavior for pg
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRE=7d

# Email (replace with production provider credentials)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Master Driving School <noreply@your-domain.com>

# Payment provider values (set your real production credentials)
STARPAY_MODE=prod
STARPAY_PROD_BASE_URL=https://financeapi.wallytglobal.com/finance-payment-service
STARPAY_PROD_MCH_ID=YOUR_MERCHANT_ID
STARPAY_PROD_SECRET_KEY=YOUR_SECRET_KEY
STARPAY_PROD_PIN=YOUR_PIN
STARPAY_USE_SECRET_SIGNING=false
